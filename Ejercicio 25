// Parámetros Formales: 'nombre' y 'edad' son los espacios vacíos [cita: 314]
SubProceso validarIngreso ( nombre, edad )
	Si edad >= 18 Entonces
		Escribir "Acceso concedido a: ", nombre;
	SiNo
		Escribir "Acceso denegado. ", nombre, " es menor de edad.";
	FinSi
FinSubProceso
Proceso Principal
	Definir usuario como carácter;
	Definir edadUsuario Como Entero;
	usuario <- "Esteban";
	edadUsuario <- 17;
	// Argumentos Reales: 'usuario' y 'edadUsuario' son los datos concretos [cita: 315]
	validarIngreso(usuario, edadUsuario);
FinProceso
