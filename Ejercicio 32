Algoritmo lLENAR_MATRIZ
	Dimension notas[3,2]
	Definir i,j Como Entero
	Para i<-1 hasta 3 Hacer
		Para j<-1 Hasta 2 Hacer
			Escribir"Ingrese  la nota del alumno",i,"en el curso",j;
			Leer notas[i,j]
			
		FinPara
	FinPara
	 suma<-0
	Para i<-1 hasta 3 Hacer
		suma<-suma+notas[i,1]
		
		//Cmbio de fila
		
	FinPara
	Escribir "LA SUMA ES",suma
FinAlgoritmo
